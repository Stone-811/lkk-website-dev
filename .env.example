# App
NEXT_PUBLIC_SITE_URL=https://l-kk.tw

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Emulator (for local development)
# FIRESTORE_EMULATOR_HOST=localhost:8080

# Auth
JWT_SECRET=your-jwt-secret-here-at-least-32-characters

# WordPress Backend (internal URL, proxied via Next.js rewrites)
WORDPRESS_BACKEND_URL=https://wp-backend.l-kk.tw

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@l-kk.tw
LEAD_NOTIFY_EMAIL=admin@l-kk.tw

# Anti-spam (Cloudflare Turnstile)
TURNSTILE_SECRET_KEY=your-turnstile-secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
