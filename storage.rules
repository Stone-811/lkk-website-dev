rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*') &&
             request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    // Public read for all images
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
    }

    // Store images
    match /stores/{storeId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
    }

    // Coach photos
    match /coaches/{coachId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
    }

    // Lecturer photos (練健康講師、合作講師、海外授權講師)
    match /lecturers/{lecturerId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
    }

    // Home page assets
    match /home/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
    }
  }
}
